# Get these at https://my.telegram.org under "API development tools"
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Your phone number in international format, for example +79991234567
TELEGRAM_PHONE=

# Optional: all new tasks will be sent to this project unless you override it
SINGULARITY_DEFAULT_PROJECT=

# Yandex Calendar CalDAV access
YANDEX_CALDAV_URL=https://caldav.yandex.ru
YANDEX_LOGIN=
YANDEX_APP_PASSWORD=
YANDEX_TIMEZONE=Europe/Moscow
YANDEX_ORGANIZER_NAME=

# Optional: used when an attendee is not found in contacts.json.
# OAuth permissions: directory:read_organization, directory:read_users.
YANDEX_360_OAUTH_TOKEN=
YANDEX_360_ORG_ID=
