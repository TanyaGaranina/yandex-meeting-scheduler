# Yandex Calendar CalDAV access
YANDEX_CALDAV_URL=https://caldav.yandex.ru
YANDEX_LOGIN=
YANDEX_APP_PASSWORD=
YANDEX_TIMEZONE=Europe/Moscow
YANDEX_ORGANIZER_NAME=

# Optional: contact lookup via Yandex CardDAV.
# Requires a separate app password of type "Contacts".
YANDEX_CARDDAV_LOGIN=
YANDEX_CARDDAV_APP_PASSWORD=

# Optional: used when an attendee is not found in contacts.json.
# OAuth permissions: directory:read_organization, directory:read_users.
YANDEX_360_OAUTH_TOKEN=
YANDEX_360_ORG_ID=
